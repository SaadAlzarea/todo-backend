{
  "openapi": "3.0.0",
  "info": {
    "title": "Todo App API",
    "version": "1.0.0",
    "description":"there are endpoint for todo project"
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],

  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  },

  "security": [
    {
      "bearerAuth": []
    }
  ],

  "tags": [
    {
      "name": "User",
      "description": "User management APIs"
    },
    {
      "name": "Todo",
      "description": "Todo management APIs"
    }
  ],

  "paths": {
    "/api/todo-app/user/register": {
      "post": {
        "tags": ["User"],
        "summary": "Register new user",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "username": "superadmin1",
                "email": "superadmin1@test.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful"
          }
        }
      }
    },

    "/api/todo-app/user/login": {
      "post": {
        "tags": ["User"],
        "summary": "User login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "email": "user1@test.com",
                "password": "123456"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful"
          }
        }
      }
    },

    "/api/todo-app/user/all-user": {
      "post": {
        "tags": ["User"],
        "summary": "Get all users (super admin)",
        "responses": {
          "200": {
            "description": "Fetch all users successfully"
          }
        }
      }
    },

    "/api/todo-app/todo/create": {
      "post": {
        "tags": ["Todo"],
        "summary": "Create new todo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "title": "Finish project",
                "body": "Complete backend logic",
                "progress": "50%",
                "priority": "critical",
                "status": "in-progress"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Todo created successfully"
          }
        }
      }
    },

    "/api/todo-app/todo/delete-todo": {
      "delete": {
        "tags": ["Todo"],
        "summary": "Delete todo",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "todoId": "146ea28f1352a001"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Deleted successfully"
          }
        }
      }
    },

    "/api/todo-app/todo/update-todo/{todoId}": {
      "put": {
        "tags": ["Todo"],
        "summary": "Update todo",
        "parameters": [
          {
            "name": "todoId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "title": "updated title",
                "body": "updated body",
                "progress": "80%",
                "priority": "high",
                "status": "in-progress"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated successfully"
          }
        }
      }
    },

    "/api/todo-app/todo/get-todo-list": {
      "post": {
        "tags": ["Todo"],
        "summary": "Get todos with pagination",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "example": {
                "page": 1,
                "limit": 10
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Todos fetched successfully"
          }
        }
      }
    }
  }
}